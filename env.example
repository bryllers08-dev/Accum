# ── REQUIRED ──────────────────────────────────────────────────────────────────
DERIV_API_TOKEN=your_deriv_token_here
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key_here
SUPABASE_BUCKET=botdata

# ── RAILWAY ───────────────────────────────────────────────────────────────────
PORT=8080
PERSIST_DIR=/tmp/accum_botdata

# ── COLLECTION ────────────────────────────────────────────────────────────────
COLLECT_MINS=30           # Phase 1 window (minutes). Recalibrates every 30min.
ROLLING_MAX_HOURS=2       # Max CSV history to keep on disk

# ── CONTRACT ──────────────────────────────────────────────────────────────────
GROWTH_RATE=2             # Starting growth rate: 1 / 2 / 3 / 5 (%). Advisor adjusts.
TARGET_TICKS=15           # Ticks to hold before E1 (profit target) exit fires
MAX_HOLD_TICKS=40         # Absolute ceiling — exits regardless after this many ticks

# ── PAYOUT RATCHET ────────────────────────────────────────────────────────────
PAYOUT_TARGET_1=1.30      # Take profit if payout >= 1.30× stake (ticks 1 → target/3)
PAYOUT_TARGET_2=1.80      # Take profit if payout >= 1.80× stake (ticks target/3 → 2/3)
PAYOUT_TARGET_3=2.50      # Take profit if payout >= 2.50× stake (ticks 2/3 → max)

# ── EXIT GATES ────────────────────────────────────────────────────────────────
EXIT_SIGMA_MULT=1.8       # Exit if sigma > sigma_gate × this multiplier (E2)
EXIT_SPIKE_MULT=1.5       # Exit if spike > spike_gate × this multiplier (E3)

# ── STAKE / RISK ──────────────────────────────────────────────────────────────
BASE_STAKE=1.0
MARTI_MULT=2.0            # Martingale multiplier after a loss
MARTI_STEPS=1             # Max martingale steps (1 = one step up then reset)
LOSS_COOLDOWN=60          # Seconds to wait after a loss before next entry
TARGET_PROFIT=20.0        # Session profit target ($) — bot stops trading when hit
STOP_LOSS=10.0            # Session stop loss ($) — bot stops trading when hit

# ── ML ENSEMBLE ───────────────────────────────────────────────────────────────
XGB_THRESHOLD=0.70        # XGBoost minimum probability to vote YES
LR_THRESHOLD=0.72         # LogReg minimum probability to vote YES
ISO_CONTAMINATION=0.15    # IsoForest contamination rate for anomaly threshold

# ── DERIV ─────────────────────────────────────────────────────────────────────
DERIV_APP_ID=1089         # Deriv app ID (1089 = public demo, use your own for prod)
